# Anthropic — clé serveur (jamais exposée au client)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# Supabase — public (safe côté client)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxxxx

# Supabase — service role (server only, JAMAIS au client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Assistimmo

# Google Maps — optionnel mais recommandé
# Active Street View (façade) dans Tom. Sans cette clé, fallback sur carte OSM.
# Setup : console.cloud.google.com → Enable APIs: "Maps Static API" + "Street View Static API"
# Free tier : 200 $ de crédit/mois (~28k requêtes Street View, largement suffisant)
GOOGLE_MAPS_API_KEY=

# Optionnel — wave 2+
YOUSIGN_API_KEY=
